# Copy to .env and fill in values (do NOT commit .env)
# Enable/disable email alerts
EMAIL_ENABLED=true

# Recipient (comma-separated allowed)
EMAIL_TO=travweber67@gmail.com

# Optional: override From header (defaults to SMTP_USER)
EMAIL_FROM=

# SMTP settings (example: Gmail App Password)
SMTP_HOST=smtp.gmail.com
SMTP_PORT=587
SMTP_USER=youraccount@gmail.com
SMTP_PASS=your_app_password_here

# Optional: subject prefix
EMAIL_SUBJECT_PREFIX=[GitHub-Expo]
